{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM (LocalCode)",
      "options": {
        "baseURL": "{env:LITELLM_API_BASE}/v1",
        "apiKey": "{env:LITELLM_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-6":      { "name": "Claude Sonnet 4.6 (via LiteLLM)" },
        "claude-opus-4-7":        { "name": "Claude Opus 4.7 (via LiteLLM)" },
        "claude-haiku-4-5":       { "name": "Claude Haiku 4.5 (via LiteLLM)" },
        "gpt-4o":                 { "name": "GPT-4o (via LiteLLM)" },
        "gpt-4o-mini":            { "name": "GPT-4o mini (via LiteLLM)" },
        "llama3.1-local":         { "name": "Llama 3.1 (local Ollama)" },
        "qwen2.5-coder-local":    { "name": "Qwen2.5-Coder 7B (local Ollama)" }
      }
    }
  }
}
