APP_NAME="LocalCode Orchestrator"
ENV=dev
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# ── Storage ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/orchestrator

# ── LiteLLM proxy (front door for every model call) ─────────────────────────
LITELLM_API_BASE=http://localhost:4000
LITELLM_MASTER_KEY=sk-localcode-master
LITELLM_SALT_KEY=salt-localcode
# Virtual key the backend uses for chat completions and spend lookups.
# Mint with: `make litellm-keygen BUDGET=10` (writes the key to stdout).
LITELLM_API_KEY=

# ── Upstream provider keys (only the ones you actually use) ─────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_API_BASE=http://host.docker.internal:11434

# ── OpenCode server ──────────────────────────────────────────────────────────
OPENCODE_BASE_URL=http://localhost:4096

# ── Claude auth ──────────────────────────────────────────────────────────────
# When true (default), the Claude provider uses the host's `claude login` token —
# spawned `claude` CLI reads ~/.claude/. Tradeoff: those turns bypass LiteLLM, so
# they don't appear in the budget bar (spend is on your Claude subscription).
# Set to false to force routing through LiteLLM with ANTHROPIC_API_KEY.
CLAUDE_USE_NATIVE_AUTH=true

# ── Defaults & catalog ───────────────────────────────────────────────────────
# provider:model — provider is `claude` (claude-agent-sdk) or `opencode` (opencode server).
# model is whatever LiteLLM exposes in litellm/config.yaml under `model_name`.
DEFAULT_PROVIDER=claude
DEFAULT_MODEL=claude-sonnet-4-6
MODEL_CATALOG=claude:claude-opus-4-7,claude:claude-sonnet-4-6,claude:claude-haiku-4-5,opencode:openai/gpt-5.5-pro,opencode:openai/gpt-5.5,opencode:openai/gpt-5.5-fast,opencode:openai/gpt-5.4,opencode:openai/gpt-5.4-mini,opencode:openai/gpt-5.3-codex,opencode:opencode/big-pickle

# ── Daily budget (USD) shown on the budget bar ───────────────────────────────
DAILY_BUDGET_USD=10.00
