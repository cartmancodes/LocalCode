APP_NAME="LocalCode Orchestrator"
ENV=dev
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# ── Storage ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/orchestrator

# ── OpenCode server ──────────────────────────────────────────────────────────
OPENCODE_BASE_URL=http://localhost:4096

# ── Defaults & catalog ───────────────────────────────────────────────────────
# provider:model — provider is `claude` (claude-agent-sdk) or `opencode` (opencode server).
DEFAULT_PROVIDER=claude
DEFAULT_MODEL=claude-sonnet-4-6
MODEL_CATALOG=fleet:default,claude:claude-opus-4-7,claude:claude-sonnet-4-6,claude:claude-haiku-4-5,opencode:openai/gpt-5.5-pro,opencode:openai/gpt-5.5,opencode:openai/gpt-5.5-fast,opencode:openai/gpt-5.4,opencode:openai/gpt-5.4-mini,opencode:openai/gpt-5.3-codex,opencode:opencode/big-pickle
