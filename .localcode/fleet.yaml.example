# Example fleet configuration — copy to .localcode/fleet.yaml in any project.
#
# A workflow IS its agents. Only roles you list under `roles:` are part of
# this workflow — there is no "disabled" flag. Add or remove an agent by
# adding / deleting its key.
#
# Resolution order (first hit wins):
#   1. $LOCALCODE_FLEET_CONFIG (absolute path, YAML or JSON)
#   2. <cwd>/.localcode/fleet.{yaml,yml,json}
#   3. <orchestrator-cwd>/.localcode/fleet.{yaml,yml,json}
#
# See docs/fleet-config.md for the full spec.

name: opus-led
max_steps: 4

# When there's no planner (or planning fails), this role runs against the
# raw user prompt. Must be one of the roles listed below.
entry_role: coder

# Workflow membership. Drop any role to remove it from this workflow.
# Per-role fields fall back to the role library, so writing
#   coder: { model: gpt-5.4 }
# is enough — system_prompt and provider keep their defaults.
roles:
  planner:
    provider: claude
    model: claude-opus-4-7

  developer:
    provider: claude
    model: claude-opus-4-7

  coder:
    provider: opencode
    model: openai/gpt-5.3-codex

  reviewer:
    provider: claude
    model: claude-haiku-4-5

# Code-only workflow — drop everything except the coder:
#
# name: code-only
# entry_role: coder
# roles:
#   coder:
#     provider: opencode
#     model: openai/gpt-5.3-codex

# Plan + code (no design, no review):
#
# name: plan-and-code
# entry_role: coder
# roles:
#   planner: { provider: claude, model: claude-sonnet-4-6 }
#   coder:   { provider: opencode, model: openai/gpt-5.3-codex }
