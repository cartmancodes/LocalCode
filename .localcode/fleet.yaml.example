# Example fleet configuration — copy to .localcode/fleet.yaml in any project.
# Every field is optional; anything you omit falls back to the built-in default
# (see GET /api/fleet/config for the live values). See docs/fleet.md for the
# full spec.
#
# Resolution order:
#   1. $LOCALCODE_FLEET_CONFIG (absolute path, YAML or JSON)
#   2. <cwd>/.localcode/fleet.{yaml,yml,json}
#   3. <orchestrator-cwd>/.localcode/fleet.{yaml,yml,json}

name: opus-led
max_steps: 4

roles:
  # Decomposes the user request into developer / coder / reviewer steps.
  # Outputs JSON. Sonnet is the default — Opus gives better plans on hard
  # tasks but is slower and pricier.
  planner:
    provider: claude
    model: claude-opus-4-7

  # Designs the approach for a step (interfaces, edge cases). No code. Skip
  # this role from your plan when steps are mechanical.
  developer:
    provider: claude
    model: claude-opus-4-7

  # Implements the step using file-edit / bash tools.
  coder:
    provider: opencode
    model: openai/gpt-5.3-codex

  # Gates the previous step's output (LGTM / NACK).
  reviewer:
    provider: claude
    model: claude-haiku-4-5

  # You can also override `system_prompt` per role if you want to nudge tone
  # or add project-specific conventions. Defaults already enforce strict-JSON
  # planning and "no code in developer / minimal coder / terse reviewer."
  # Example:
  # coder:
  #   provider: opencode
  #   model: openai/gpt-5.3-codex
  #   system_prompt: |
  #     You are the Coder. Always run `pytest -q` after edits and
  #     paste the result. Use `ruff format` on any Python you touch.
